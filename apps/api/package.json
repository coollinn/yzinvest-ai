{
  "name": "@yzinvest/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "build": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply yzinvest --local",
    "db:migrate:remote": "wrangler d1 migrations apply yzinvest --remote",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@yzinvest/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@types/bcryptjs": "^2.4.6",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.5.4",
    "wrangler": "^3.99.0"
  }
}
